{
  "name": "@ork/harness",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ork/kernel": "workspace:*",
    "@ork/shell": "workspace:*",
    "@ork/tools": "workspace:*",
    "ai": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "2.0.3",
    "@types/node": "^24.0.0",
    "msw": "^2.14.6",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
